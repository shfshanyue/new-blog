---
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Pagination from "@components/Pagination.astro";
import Card from "@components/Card";
import { SITE } from "@config";

export interface Props {
  currentPage: number;
  totalPages: number;
  paginatedPosts: CollectionEntry<"wechat">[];
}

const { currentPage, totalPages, paginatedPosts } = Astro.props;
---

<Layout title={`WeChat | ${SITE.title}`}>
  <Header activeNav="wechat" />
  <Main
    pageTitle="WeChat"
    pageDesc="这里的公众号内容与我的公众号保持同步，主要是一些编程知识分享"
  >
    <ul>
      {
        paginatedPosts.map(post => (
          <Card href={`/wechat/${post.id}/`} frontmatter={post.data} />
        ))
      }
    </ul>
  </Main>

  <Pagination
    {currentPage}
    {totalPages}
    prevUrl={`/wechat${currentPage - 1 !== 1 ? "/" + (currentPage - 1) : ""}/`}
    nextUrl={`/wechat/${currentPage + 1}/`}
  />

  <Footer noMarginTop={totalPages > 1} />
</Layout>
