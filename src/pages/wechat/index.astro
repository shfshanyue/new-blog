---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Wechat from "@layouts/Wechat.astro";
import { SITE } from "@config";

const wechats = await getCollection("wechat");

// 过滤和排序wechat
const filteredWechats = wechats
  .filter(note => !note.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  );

// 简单分页
const paginatedPosts = filteredWechats.slice(0, SITE.postPerPage);
---

<Wechat
  currentPage={1}
  totalPages={Math.ceil(filteredWechats.length / SITE.postPerPage)}
  paginatedPosts={paginatedPosts}
/>
